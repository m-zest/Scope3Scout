# ============================================
# Scope3Scout — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# For Vercel: add these in Project Settings > Environment Variables.
# IMPORTANT: Never commit .env with real keys.
# ============================================

# --- Supabase (required) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...

# --- TinyFish Web Agent API (Tier 1 — live web scraping) ---
# Get your key at: https://agent.tinyfish.ai/sign-up
VITE_TINYFISH_API_KEY=

# --- Google Gemini AI (Tier 2 — LLM cross-reference analysis) ---
# Get your key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# --- OpenAI (optional, reserved for future use) ---
VITE_OPENAI_API_KEY=

# --- Simulation Engine (Tier 3 — risk prediction) ---
VITE_SIMULATION_ENGINE_URL=http://localhost:8001
VITE_SIMULATION_ENGINE_KEY=

# --- Demo Mode ---
# Set to "true" to use sample data without API keys (default: true)
# Set to "false" to use real API keys for live scanning
VITE_DEMO_MODE=true
